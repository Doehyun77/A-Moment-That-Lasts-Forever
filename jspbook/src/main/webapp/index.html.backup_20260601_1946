      <button onclick="closeConfirmModal()" style="flex:1; padding:13px; border:1px solid var(--border); border-radius:10px; background:transparent; font-family:'Noto Sans KR',sans-serif; font-size:14px; color:var(--text-soft); cursor:pointer;">뒤로가기</button>
      <button id="confirm-qr-btn" onclick="closeConfirmModal(); generateQRCode();" disabled
        style="flex:2; padding:13px; border:none; border-radius:10px; background:#C8B4B0; color:white; font-family:'Noto Sans KR',sans-serif; font-size:14px; font-weight:500; cursor:not-allowed; transition:all 0.2s;">
        QR 발급
      </button>
    </div>

  </div>
</div>

<!-- ── 사이트 관리 QR 모달 ── -->
<div id="site-manage-preview-modal" style="display:none; position:fixed; inset:0; background:rgba(44,31,26,0.5); z-index:500; align-items:center; justify-content:center;">
  <div style="background:var(--white); border-radius:24px; padding:28px 24px; width:calc(100% - 48px); max-width:360px; position:relative;">
    <!-- 닫기 버튼 -->
    <button onclick="closeSiteManagePreview()" style="position:absolute; top:16px; right:16px; border:none; background:transparent; font-size:18px; color:var(--text-muted); cursor:pointer; line-height:1; padding:4px 8px;">✕</button>
    <!-- 헤더 -->
    <div style="text-align:center; margin-bottom:20px;">
      <div style="font-size:10px; color:var(--rose); font-weight:700; letter-spacing:0.15em; margin-bottom:6px;">QR CODE</div>
      <div id="site-manage-preview-title" style="font-family:'Cormorant Garamond',serif; font-size:24px; color:var(--deep-rose); font-weight:400;"></div>
      <div id="site-manage-preview-date" style="font-size:12px; color:var(--text-muted); margin-top:4px;"></div>
      <div id="site-manage-preview-status" style="font-size:11px; color:var(--text-muted); margin-top:4px; line-height:1.6;"></div>
    </div>
    <!-- QR 코드 -->
    <div id="site-manage-preview-qr" style="display:flex; justify-content:center; align-items:center; padding:16px; background:var(--cream); border-radius:16px; margin-bottom:18px;"></div>
    <!-- 링크 복사 -->
    <div style="display:flex; gap:8px; align-items:center; background:var(--cream); border-radius:10px; padding:10px 14px; margin-bottom:16px;">
      <input id="site-manage-preview-link" readonly style="flex:1; border:none; background:transparent; font-size:11px; color:var(--text-muted); font-family:'Noto Sans KR',sans-serif; outline:none; min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
      <button onclick="copySitePreviewLink()" style="border:none; background:transparent; color:var(--rose); font-size:11px; font-weight:700; cursor:pointer; white-space:nowrap; font-family:'Noto Sans KR',sans-serif; flex-shrink:0;">복사</button>
    </div>
    <!-- 액션 버튼 -->
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px;">
      <button onclick="downloadSitePreviewQr()" style="height:42px; border:1px solid var(--border); border-radius:10px; background:transparent; font-family:'Noto Sans KR',sans-serif; font-size:13px; color:var(--text-soft); cursor:pointer; font-weight:500;">QR 저장</button>
      <button onclick="openSitePreviewLink()" style="height:42px; border:none; border-radius:10px; background:var(--deep-rose); font-family:'Noto Sans KR',sans-serif; font-size:13px; color:white; cursor:pointer; font-weight:500;">하객 화면</button>
    </div>
  </div>
</div>

<!-- ── 청첩장 모달 ── -->
<div id="invitation-modal" style="display:none; position:fixed; inset:0; z-index:500;">

  <!-- 이미지 뷰어 (기존 카드 스타일) -->
  <div id="invitation-img-view" style="display:none; position:absolute; inset:0; background:rgba(44,31,26,0.82); align-items:center; justify-content:center;" onclick="closeInvitationModal()">
    <div style="background:var(--white); border-radius:16px; width:calc(100% - 48px); max-width:420px; max-height:90vh; overflow-y:auto;" onclick="event.stopPropagation()">
      <div style="display:flex; align-items:center; justify-content:space-between; padding:20px 20px 16px; border-bottom:1px solid var(--border);">
        <div style="font-family:'Cormorant Garamond',serif; font-size:20px; color:var(--deep-rose);">💌 청첩장</div>
        <button onclick="closeInvitationModal()" style="border:none; background:transparent; font-size:20px; color:var(--text-muted); cursor:pointer;">✕</button>
      </div>
      <div style="padding:20px; text-align:center;">
        <img id="invitation-display-img" style="width:100%; border-radius:8px; object-fit:contain; max-height:60vh;">
      </div>
    </div>
  </div>

  <!-- URL 뷰어 (모바일 청첩장 — 폰 프레임 스타일) -->
  <div id="invitation-url-view" style="display:none; position:absolute; inset:0; background:#1C0E0A; flex-direction:column; align-items:center;">
    <div style="width:100%; max-width:430px; display:flex; align-items:center; justify-content:space-between; padding:14px 20px 10px; flex-shrink:0;">
      <span style="font-family:'Cormorant Garamond',serif; font-size:17px; color:rgba(255,210,170,0.9); letter-spacing:0.05em;">💌 모바일 청첩장</span>
      <button onclick="closeInvitationModal()" style="border:none; background:rgba(255,255,255,0.12); color:white; border-radius:50%; width:34px; height:34px; cursor:pointer; font-size:13px; display:flex; align-items:center; justify-content:center; flex-shrink:0;">✕</button>
    </div>
    <div style="width:100%; max-width:393px; flex:1; margin:0 auto; background:white; border-radius:28px 28px 0 0; overflow:hidden; box-shadow:0 -10px 40px rgba(0,0,0,0.5);">
      <iframe id="invitation-display-iframe" src="" style="width:100%; height:100%; min-height:calc(100dvh - 70px); border:none;" frameborder="0" allow="fullscreen"></iframe>
    </div>
  </div>

</div>

<!-- ── 웨딩사진 모달 ── -->
<div id="wedding-photo-modal" style="display:none; position:fixed; inset:0; background:rgba(44,31,26,0.6); z-index:400; align-items:center; justify-content:center;" onclick="closeWeddingPhotoModal()">
  <div style="background:var(--white); border-radius:16px; width:calc(100% - 48px); max-width:500px; max-height:90vh; overflow-y:auto;" onclick="event.stopPropagation()">
    <div style="display:flex; align-items:center; justify-content:space-between; padding:20px 20px 16px; border-bottom:1px solid var(--border);">
      <div style="font-family:'Cormorant Garamond',serif; font-size:20px; color:var(--deep-rose);">웨딩사진</div>
      <button onclick="closeWeddingPhotoModal()" style="border:none; background:transparent; font-size:20px; color:var(--text-muted); cursor:pointer;">✕</button>
    </div>
    <div id="wedding-display-grid" style="padding:20px; display:grid; grid-template-columns:repeat(2,1fr); gap:10px;"></div>
  </div>
</div>

<!-- ── FAQ 모달 ── -->
<div id="faq-modal" style="display:none; position:fixed; inset:0; z-index:500; flex-direction:column; background:var(--ivory);">
  <!-- 헤더 -->
  <div style="display:flex; align-items:center; justify-content:space-between; padding:18px 20px 14px; border-bottom:1px solid var(--border); background:var(--white); flex-shrink:0;">
    <div>
      <div style="font-size:10px; color:var(--rose); font-weight:600; letter-spacing:0.12em; margin-bottom:4px;">FAQ</div>
      <div style="font-family:'Cormorant Garamond',serif; font-size:20px; color:var(--deep-rose);">자주 묻는 질문</div>
    </div>
    <button onclick="closeFaqModal()" style="border:none; background:transparent; font-size:20px; color:var(--text-muted); cursor:pointer; padding:4px 8px; line-height:1;">✕</button>
  </div>
  <!-- 목록 -->
  <div id="faq-modal-list" style="flex:1; overflow-y:auto; padding:20px;"></div>
</div>

<!-- ── TOAST ── -->
<div class="toast" id="toast"></div>

<!-- ── PIN SET MODAL ── -->
<div id="pin-set-modal" style="display:none; position:fixed; inset:0; background:rgba(44,31,26,0.45); z-index:300; align-items:center; justify-content:center;">
  <div style="background:var(--white); border-radius:16px; padding:28px 24px; width:calc(100% - 48px); max-width:320px; text-align:center;">
    <div style="font-size:28px; margin-bottom:12px;">🔒</div>
    <div style="font-family:'Cormorant Garamond',serif; font-size:20px; color:var(--deep-rose); margin-bottom:8px;">삭제 번호 설정</div>
    <div style="font-size:13px; color:var(--text-muted); line-height:1.7; margin-bottom:16px;">게시물 삭제 시 사용할<br>숫자 4자리를 설정해주세요</div>
    <div style="display:flex; justify-content:center; gap:12px; margin-bottom:16px; cursor:text;" id="pin-dots" onclick="document.getElementById('delete-pin-input').focus()">
      <div class="pin-dot" id="dot-0"></div>
      <div class="pin-dot" id="dot-1"></div>
      <div class="pin-dot" id="dot-2"></div>
      <div class="pin-dot" id="dot-3"></div>
    </div>
    <input type="number" id="delete-pin-input" maxlength="4" min="0" max="9999"
      oninput="if(this.value.length>4) this.value=this.value.slice(0,4); updatePinDots(); document.getElementById('pin-set-error').textContent='';"
      onkeydown="if(event.key==='Enter') submitUpload()"
      style="position:absolute; opacity:0; width:1px; height:1px; pointer-events:none;">
    <div id="pin-set-error" style="font-size:12px; color:var(--rose); margin-bottom:12px; min-height:18px; text-align:center;"></div>
    <div style="display:flex; gap:8px;">
      <button onclick="closePinSetModal()" style="flex:1; padding:11px; border:1px solid var(--border); border-radius:8px; background:transparent; font-family:'Noto Sans KR',sans-serif; font-size:13px; color:var(--text-soft); cursor:pointer;">취소</button>
      <button onclick="submitUpload()" style="flex:1; padding:11px; border:none; border-radius:8px; background:var(--deep-rose); font-family:'Noto Sans KR',sans-serif; font-size:13px; color:white; cursor:pointer; font-weight:500;">공유하기</button>
    </div>
  </div>
</div>

<!-- ── DELETE MODAL ── -->
<div id="delete-modal" style="display:none; position:fixed; inset:0; background:rgba(44,31,26,0.45); z-index:300; align-items:center; justify-content:center;">
  <div style="background:var(--white); border-radius:16px; padding:28px 24px; width:calc(100% - 48px); max-width:320px; text-align:center;">
    <div style="font-size:28px; margin-bottom:12px;">🔑</div>
    <div style="font-family:'Cormorant Garamond',serif; font-size:20px; color:var(--deep-rose); margin-bottom:8px;">삭제 번호 확인</div>
    <div style="font-size:13px; color:var(--text-muted); line-height:1.7; margin-bottom:16px;">게시물 등록 시 설정한<br>4자리 번호를 입력해주세요</div>
    <div style="display:flex; justify-content:center; gap:12px; margin-bottom:16px; cursor:text;" id="confirm-pin-dots" onclick="document.getElementById('delete-pin-confirm').focus()">
      <div class="pin-dot" id="cdot-0"></div>
      <div class="pin-dot" id="cdot-1"></div>
      <div class="pin-dot" id="cdot-2"></div>
      <div class="pin-dot" id="cdot-3"></div>
    </div>
    <input type="number" id="delete-pin-confirm" min="0" max="9999"
      oninput="if(this.value.length>4) this.value=this.value.slice(0,4); updateConfirmDots(); document.getElementById('delete-pin-error').textContent='';"
      onkeydown="if(event.key==='Enter') deletePost()"
      style="position:absolute; opacity:0; width:1px; height:1px; pointer-events:none;">
    <div id="delete-pin-error" style="font-size:12px; color:var(--rose); margin-bottom:12px; min-height:18px; text-align:center;"></div>
    <div style="display:flex; gap:8px;">
      <button onclick="closeDeleteModal()" style="flex:1; padding:11px; border:1px solid var(--border); border-radius:8px; background:transparent; font-family:'Noto Sans KR',sans-serif; font-size:13px; color:var(--text-soft); cursor:pointer;">취소</button>
      <button onclick="deletePost()" style="flex:1; padding:11px; border:none; border-radius:8px; background:var(--deep-rose); font-family:'Noto Sans KR',sans-serif; font-size:13px; color:white; cursor:pointer; font-weight:500;">삭제하기</button>
    </div>
  </div>
</div>


